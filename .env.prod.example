# Potriv production-like environment template.
#
#   cp .env.prod.example .env.prod   # then edit the values below
#
# .env.prod is git-ignored; never commit real secrets.

# --- PostgreSQL (internal-only in docker-compose.prod.yml) ---
POSTGRES_DB=potriv
POSTGRES_USER=potriv
POSTGRES_PASSWORD=change-me-in-production

# --- JWT ---
# At least 32 random bytes; the prod profile refuses the repository placeholder.
JWT_SECRET=replace-with-at-least-32-random-bytes-base64-or-long-random-string
JWT_ISSUER=https://api.potriv.aydgn.me/api
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# --- Web ---
CORS_ALLOWED_ORIGINS=https://potriv.aydgn.me
FRONTEND_URL=https://potriv.aydgn.me
APP_BASE_URL=https://api.potriv.aydgn.me/api
SWAGGER_ENABLED=false

# --- Outbound mail ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=no-reply@potriv.aydgn.me

# --- Seeded platform system admin (override before first boot) ---
SYSTEM_ADMIN_EMAIL=admin@example.com
SYSTEM_ADMIN_PASSWORD=change-me-in-production

# --- Embedded backend monitor console (/api/admin/monitor) ---
# Disabled by default. If enabled, explicit strong credentials are mandatory;
# the prod guard refuses placeholder or short passwords.
BACKEND_CONSOLE_ENABLED=true
BACKEND_CONSOLE_USERNAME=admin
BACKEND_CONSOLE_PASSWORD=test12.!

# --- JVM ---
JAVA_OPTS=-XX:MaxRAMPercentage=75


